# Option B: Backend (Vercel + Supabase). Set VITE_API_URL to your Vercel app URL (e.g. https://your-app.vercel.app).
# Then in Vercel env set: SUPABASE_URL, SUPABASE_ANON_KEY, DATA_SECRET (the PIN for /data).
# VITE_API_URL=https://your-app.vercel.app

# Google Sheets: send results directly to a sheet (no form). Used only if VITE_API_URL is not set.
# VITE_GOOGLE_SHEETS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Google Form pre-fill (optional – app has defaults; used only if VITE_GOOGLE_SHEETS_SCRIPT_URL is not set)
# VITE_GOOGLE_FORM_BASE=https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform
